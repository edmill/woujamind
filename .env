# Replicate API Key (required for video-based sprite generation)
# Get your key from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here

# Gemini API Key (required for character analysis and prompt optimization)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Proxy server port (default: 3001)
PROXY_PORT=3001


