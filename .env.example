# Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
# NEVER commit real keys. Use .env (gitignored) for local development.
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative: Use VITE_ prefix for Vite's standard env var handling
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Replicate API Key
# Get your API key from: https://replicate.com/account/api-tokens
VITE_REPLICATE_API_KEY=your_replicate_api_key_here

# Optional: CORS allowlist for /api/replicate (comma-separated origins).
# If unset, Vercel uses VERCEL_URL; set this when self-hosting or to add custom domains.
# ALLOWED_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
